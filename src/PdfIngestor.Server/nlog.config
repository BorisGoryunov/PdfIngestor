<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Error"
      internalLogFile="${basedir}/logs/nlog-internal.log">

    <extensions>
        <add assembly="NLog.Web.AspNetCore"/>
    </extensions>

    <!-- optional, add some variabeles https://github.com/nlog/NLog/wiki/Configuration-file#variables-->
    <!-- <variable name="myvar" value="myvalue"/> -->

    <targets async="true">

        <target xsi:type="ColoredConsole"
                name="console"
                layout="${longdate} ${uppercase:${level}} [${logger}] ${replace:inner=${message}:searchFor=(\\r\\n)|(\\r)|(\\n):replaceWith=\\n:regex=true} ${replace:inner=${exception:format=tostring}:searchFor=(\\r\\n)|(\\r)|(\\n):replaceWith=\\n:regex=true} ${replace:inner=${ndc}:searchFor=(\\r\\n)|(\\r)|(\\n):replaceWith=\\n:regex=true}">
        </target>

        <target xsi:type="Null" name="null" />
    </targets>

    <rules>
        <logger name="Microsoft.AspNetCore.*" maxlevel="Info" final="true" />
		
        <logger name="Microsoft.EntityFrameworkCore.*" maxlevel="Info" final="true" />
		
        <logger name="*"
                minlevel="Trace"
                writeTo="console" />
    </rules>
</nlog>
